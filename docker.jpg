    font-size: 16px !important;
    line-height: 24px !important;
    padding: 7px 10px;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 30px;
    min-height: 30px;
}

.rt-pagination .pagination-list>li>a:hover, .rt-pagination .pagination-list>li>span:hover, .rt-pagination .pagination-list>.active>a, .rt-pagination .pagination-list>.active>a:focus, .rt-pagination .pagination-list>.active>a:hover, .rt-pagination .pagination-list>.active>span, .rt-pagination .pagination-list>.active>span:focus, .rt-pagination .pagination-list>.active>span:hover {
    color: #d6011c !important;
}

