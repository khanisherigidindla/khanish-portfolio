<!-- start Simple Custom CSS and JS -->
<script>
(function () {
  function removeWPCOMGiftingBanner() {
    const banner = document.querySelector('.wpcom-gifting-banner');
    if (banner) {
      banner.remove();
      document.body.classList.remove('has-wpcom-gifting-banner');
    }
  }

  removeWPCOMGiftingBanner();

  new MutationObserver(removeWPCOMGiftingBanner).observe(
    document.documentElement,
    { childList: true, subtree: true }
  );
})();
</script><!-- end Simple Custom CSS and JS -->
<!-- start Simple Custom CSS and JS -->
<style>
.has-wpcom-gifting-banner .wpcom-gifting-banner {
    display: none !important;
    visibility: hidden !important;
    pointer-events: none !important;
	min-height: 0 !important;
}</style>
<!-- end Simple Custom CSS and JS -->
<!-- start Simple Custom CSS and JS -->
<style>
.archive.author{
    #infinite-footer{
        display: none !important;
    }
    
    .ast-article-post{
        display: flex;
        margin: 10px !important;
        width: calc(33.33% - 20px);
        padding: 0px !important;
		.post-thumb{
			img{
				width: 100% !important;
			}
		}
        .entry-title{
            height: auto !important;
            padding: 10px 20px;
            margin: 0px 0px 10px 0px;
        }
        .entry-header{
            display: none !important;
        }
    }
    
    @media only screen and (max-width: 923px){
        .ast-article-post{
            width: calc(50% - 20px);
        }
    }
    
    @media only screen and (max-width: 599px){
        .ast-article-post{
            width: calc(100% - 20px);
        }
    }
}</style>
<!-- end Simple Custom CSS and JS -->
<!-- start Simple Custom CSS and JS -->
<style>
.site-header-primary-section-left {
    width: max-content;
    padding-right: 50px;
}
.site-header-primary-section-right {
    width: 100%;
    display: flex;
    justify-content: space-between;
    font-weight: 700;
}
.site-primary-header-wrap .ast-builder-grid-row {
    display: flex;
}
body.archive #primary{
	margin-top:0 !important
}
div#ast-mobile-header .site-header-primary-section-right {
     justify-content: flex-end !important;
}
@media (min-width:1024px){
body.archive .ast-archive-description {
    padding: 80px 80px 80px 80px !important;
    max-width: 550px !important;	
	}
}

body.archive .ast-archive-description {
    background: url(/wp-content/uploads/2023/04/title-bg-cut-square.png);
    background-size: cover;
    background-repeat: no-repeat;
    background-position: top center;
     display: flex !important;
	flex-direction:column;
    box-shadow: 0 2px 27px 0 #00000017;
	transform: translateY(calc(50%));
    position: relative;
	margin-bottom: 220px;
	min-height: 350px;
    justify-content: center;
}
.archiveHeroSec{
	background: url(/wp-content/uploads/2023/04/industries-hero-bg.jpg);
	background-position: center;
    background-size: cover;
    position: absolute;
    height: 450px;
    width: 100vw;
    margin-lefT: -50vw;
    left: 50%;
    top: 0;
}
body.archive h1.page-title.ast-archive-title {
   font-weight: 700;
    position: relative;
    z-index: 99 !important;
    display: block;
    background: linear-gradient(270deg, #D6001C, #6A1F7A) !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent;
}

body.archive .ast-archive-description p {
    position: relative;
    z-index: 99;
    font-size: 16px;
    font-weight: 500;
}
body.archive .ast-row {
    display:flex;
    flex-wrap:wrap;
}
body.archive .ast-row article .ast-post-format-{
    box-shadow: 0px 2px 10px 0px rgba(0, 0, 0, 0.2)!important;
    background: #fff;
    transition: 0.4s;
    border-radius: 10px;
	overflow: hidden;
	padding-bottom: 10px;
}
body.archive .ast-row article .ast-post-format- .entry-content {
    display: none;
}
body.archive .ast-row article .ast-post-format- header{
   padding:10px 20px;
}
body.archive .ast-row article h2.entry-title, body.archive .ast-row article h2.entry-title a{
  font-size: 18px !important;
    line-height: 26px !important;
    font-weight: 700 !important;
    height: 52px;
    overflow: hidden;
    order: 2;
}
body.archive .ast-row article .ast-post-format- header .entry-meta {
    order: 1;
}
body.archive .ast-row article .ast-post-format- header{
   margin-bottom: 0px !important;
    display: flex;
    flex-direction: column;
    padding-bottom: 45px;
    min-height: 160px;
}

body.archive .ast-row article .ast-post-format- .post-thumb{
	 float: none;
    width: auto;
    border-radius: 10px;
    height: 255px;
    overflow: hidden;
    margin-bottom: 10px;
}
body.archive .ast-row article .ast-post-format- .post-thumb img {
 min-height: 255px;
    transition: 0.5s;
    object-fit: cover;
    width: auto;
}
body.archive .ast-row article .ast-post-format- .post-thumb:hover img{
    transform:scale(1.05);
}

.catListTemp .elementor-section .elementor-container {
    margin-left: 0 !important;
}

.catListTemp .elementor-widget-wrap {
    padding: 0 !important;
}
@media (min-width:1025px){
   body.archive .ast-row article{
   max-width:33.33%;
} 
}

@media (min-width:769px) and  (max-width:1024px){
   body.archive .ast-row article{
   max-width:50%;
} 
}
@media (max-width:768px){
   body.archive .ast-row article{
   max-width:100%;
} 
}

body.archive .ast-row article .ast-post-format-  .entry-content {
    display: none;
}
body.archive .ast-row article .ast-post-format- .cat-links {
    color: transparent;
}
body.archive  .author-avatar{
	pointer-events:none;
}
body.archive span.author-avatar {
    border-radius: 50px;
    overflow: hidden;
    width: 30px;
    height: 30px;
    display: inline-block;
}
body.archive span.posted-by.vcard.author {
    margin-top: 1rem;
    display: block;
    position: absolute;
    bottom: 10px;
}
body.archive span.posted-by.vcard.author a {
    display: flex;
    align-items: center;
    font-size: 12px;
    font-weight: 700 !important;
}
@media (max-width:500px){
  section.ast-archive-description {
    padding: 20px !important;
}  
}
body.archive span.author-name {
    margin-left: 10px;
}
body.archive span.posted-by.vcard.author {
    margin-top: 1rem;
    display: block;
}
    .ast-article-single .rt-detail.rt-el-content-wrapper {
    border: 0px;
}
div.sharedaddy,div#jp-relatedposts{display:none !important;}
.ast-article-single .tpg-post-holder {
    border: 0px;
    box-shadow: 0 2px 27px 0 #0000001a !important;
    border-radius: 10px;
    overflow: hidden;
}

.ast-article-single .entry-title-wrapper .entry-title {
    font-size: 18px !important;
    line-height: 26px !important;
    font-weight: 700 !important;
    height: 52px;
    overflow: hidden;
}

.ast-article-single .entry-title-wrapper .entry-title a {
    font-weight: 700 !important;
}

.ast-article-single .tpg-el-image-wrap img {
    min-height: 255px;
    transition: 0.5s;
    max-height: 255px;
    min-width: 100%;
}

.ast-article-single span.categories-links a {
    color: #6E1578;
    font-weight: bold;
    font-size: 12px;
    position: relative;
    display: inline-block;
    padding: 2px 20px 2px 0;
}

.ast-article-single span.rt-separator {
    display: none !important;
}

.ast-article-single span.categories-links a:not(:last-child):after {
    content: "";
    display: block;
    background: #E2E1E1;
    height: 15px;
    width: 1px;
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
}

.ast-article-single i.flaticon-folder {
    display: none;
}
.rt-img-holder.tpg-el-image-wrap.has-no-thumbnail {
    margin: -15px -25px 0 !important;
}
.ast-article-single span.author.has-author-avatar a {
    font-size: 12px;
    font-weight: 700 !important;
    color: #2A2E3A;
    line-height: 18px;
}

.ast-article-single span.date {
    font-size: 12px;
    font-weight: 700 !important;
    color: #4E5761;
    line-height: 20px;
    display: none !important;
}

.ast-article-single span.date a {
    line-height: 18px;
}

.ast-article-single .entry-title-wrapper {
    margin-top: 50px;
}

.ast-article-single .post-meta-tags  span.categories-links {
    position: absolute;
    max-width: 100%;
    bottom: 80px;
    left: 0;
    height: 40px;
    align-content: flex-start;
}

.ast-article-single .post-meta-tags.rt-el-post-meta {
    position: relative;
    justify-content: space-between;
}


.ast-article-single .rt-img-holder.tpg-el-image-wrap.has-thumbnail {
    margin: -15px -25px 0;
}
.ntgTableContent ul.elementor-toc__list-wrapper {
    padding-left: 0;
    margin-left: 10px;
    font-weight: 700;
}
.infinite-wrap {
    display: none;
}

.ast-pagination .nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
}
span.posted-on {
    position: absolute;
    right: 0;
    bottom: 15px;
    text-align: right;
    padding-right: 20px;
    width: max-content;
    left: auto !important;
    font-size: 12px;
    font-weight: 700;
}

body.archive span.published, body.archive span.updated, body.archive span.author-name {
     color: #757575 !important;
}
.post-thumb-img-content.post-thumb:after,.grid-thumbnail-wrapper:after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    background: linear-gradient(270deg, #D6001C, #6A1F7A) !important;
    z-index: 1;
    height: 4px;
    transition:0.8s;
}
body.archive .ast-row article:hover .post-thumb-img-content.post-thumb:after,
.customPostGrid .grid-item:hover .grid-thumbnail-wrapper:after{
    width:100%;
}
body.archive .ast-row article:hover h2.entry-title,.customPostGrid .grid-item:hover .grid-title{
     background: linear-gradient(270deg, #D6001C, #6A1F7A) !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent;
}</style>
<!-- end Simple Custom CSS and JS -->
