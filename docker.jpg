<script>
jQuery("document").ready(function () {
	let thumbLink = jQuery(".rt-img-holder.tpg-el-image-wrap.has-no-thumbnail a");
if(typeof thumbLink != "undefined"){
  for(let i=0;thumbLink.length>i;i++){
      if(thumbLink.eq(i).find("img").length==0){
        thumbLink.eq(i).prepend("<img src='/wp-content/uploads/2023/05/defualtBlog-thumbnail.jpeg'>")
    }
}  
}
let cthumbLink = jQuery(".customPostGrid a.grid-thumbnail");
if(typeof cthumbLink != "undefined"){
  for(let i=0;cthumbLink.length>i;i++){
      if(cthumbLink.eq(i).find("img").length==0){
        cthumbLink.eq(i).prepend("<img src='/wp-content/uploads/2023/05/defualtBlog-thumbnail.jpeg'>")
    }
}  
}	
    function addTargBlank() {
        let links = jQuery("a");
        let domain = location.hostname;
        for (let i = 0; links.length > i; i++) {
           /* if (!links.eq(i)[0].href.includes(domain)) {
                links.eq(i)[0].target = "_blank"
            }*/
			if (!links.eq(i)[0].href.includes("nashtechglobal.com")) {
                links.eq(i)[0].target = "_blank"
            }
			
        }
    }addTargBlank();

	 jQuery(function(){
	 var lastScrollTop = 0, delta = 5;
	 jQuery(window).scroll(function(){
		 if (jQuery(window).scrollTop() > 112) { 
   var nowScrollTop = jQuery(this).scrollTop();
		 if(Math.abs(lastScrollTop - nowScrollTop) >= delta){
		 	if (nowScrollTop > lastScrollTop){
				 jQuery("header#masthead").addClass("unStickyHeader");
        jQuery("header#masthead").removeClass("stickyHeader");
		 	} else {
		 	jQuery("header#masthead").addClass("stickyHeader");
        jQuery("header#masthead").removeClass("unStickyHeader");
			}
		 lastScrollTop = nowScrollTop;
		 }
}
		  else{
			jQuery("header#masthead").removeClass("stickyHeader");
			jQuery("header#masthead").removeClass("unStickyHeader");  
     		}
	 });
 });
});</script>
